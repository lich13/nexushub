#!/usr/bin/env bash
set -Eeuo pipefail

unit="nexushub-codex-update-$(date +%s)-$$"

exec systemd-run \
  --wait \
  --collect \
  --pipe \
  --unit="${unit}" \
  --property=User=root \
  --property=Group=root \
  --property=Type=exec \
  --property=WorkingDirectory=/home/ubuntu/codex-workspace \
  --property=ProtectSystem=no \
  --property=ProtectHome=no \
  /usr/bin/env bash -lc '
set -Eeuo pipefail
/home/ubuntu/codex-admin/bin/codex-cloud-update --no-prune "$@"
/home/ubuntu/codex-admin/bin/codex-cloud-prune
codex --version
codex mcp list
/home/ubuntu/codex-admin/bin/codex-cloud-doctor
' nexushub-codex-update "$@"
