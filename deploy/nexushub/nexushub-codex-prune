#!/usr/bin/env bash
set -Eeuo pipefail

unit="nexushub-codex-prune-$(date +%s)-$$"

exec systemd-run \
  --wait \
  --collect \
  --pipe \
  --unit="${unit}" \
  --property=User=root \
  --property=Group=root \
  --property=Type=exec \
  --property=WorkingDirectory=/home/ubuntu/codex-workspace \
  --property=ProtectSystem=no \
  --property=ProtectHome=no \
  /home/ubuntu/codex-admin/bin/codex-cloud-prune "$@"
