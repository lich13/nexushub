#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="nexushub"
MODE="dry-run"

LEGACY_SERVICE="codex-sentinel-server.service"
NEXUSHUB_SERVICE="${NEXUSHUB_SERVICE:-nexushub}"
HEALTH_URL="${NEXUSHUB_HEALTH_URL:-http://127.0.0.1:15742/healthz}"
BACKUP_ROOT="${NEXUSHUB_LEGACY_BACKUP_ROOT:-/opt/nexushub/backups/probe-legacy}"
STAMP="${NEXUSHUB_LEGACY_CLEANUP_TIMESTAMP:-$(date +%Y%m%d-%H%M%S)}"

UNIT_PATH="${NEXUSHUB_LEGACY_UNIT_PATH:-/etc/systemd/system/codex-sentinel-server.service}"
OPT_DIR="${NEXUSHUB_LEGACY_OPT_DIR:-/opt/codex-sentinel-server}"
ETC_DIR="${NEXUSHUB_LEGACY_ETC_DIR:-/etc/codex-sentinel-server}"
STATE_DIR="${NEXUSHUB_LEGACY_STATE_DIR:-/var/lib/codex-sentinel-server}"
BIN_PATH="${NEXUSHUB_LEGACY_BIN_PATH:-/usr/local/bin/codex-sentinel-server}"
HOOKS_JSON="${NEXUSHUB_LEGACY_HOOKS_JSON:-/root/.codex/hooks.json}"
INSTALL_OWNER="${NEXUSHUB_INSTALL_OWNER:-root}"
INSTALL_GROUP="${NEXUSHUB_INSTALL_GROUP:-root}"

log() { printf '[%s-probe-legacy-cleanup] %s\n' "${APP_NAME}" "$*"; }
die() { printf '[%s-probe-legacy-cleanup] ERROR: %s\n' "${APP_NAME}" "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
Clean old codex-sentinel-server runtime files after NexusHub Probe is healthy.

Usage:
  sudo nexushub-probe-legacy-cleanup --dry-run
  sudo nexushub-probe-legacy-cleanup --execute

--dry-run  lists detected legacy service, unit, runtime paths, and hooks.json references.
--execute  requires systemctl is-active nexushub and http://127.0.0.1:15742/healthz,
           backs up detected files under /opt/nexushub/backups/probe-legacy/<timestamp>/,
           then removes only codex-sentinel-server service/runtime artifacts and hook entries.
USAGE
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) MODE="dry-run"; shift ;;
      --execute) MODE="execute"; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown argument: $1" ;;
    esac
  done
}

require_root() {
  if [[ "${EUID}" -ne 0 && "${NEXUSHUB_LEGACY_CLEANUP_ALLOW_NON_ROOT:-0}" != "1" ]]; then
    die "run as root"
  fi
}

detect_legacy_service() {
  if systemctl is-active codex-sentinel-server.service >/dev/null 2>&1; then
    log "detect service active: codex-sentinel-server.service"
  else
    log "detect service inactive-or-missing: codex-sentinel-server.service"
  fi
}

detect_path() {
  local label="$1"
  local path="$2"
  if [[ -e "${path}" ]]; then
    log "detect ${label}: ${path}"
  else
    log "detect ${label} missing: ${path}"
  fi
}

detect_hooks() {
  if [[ ! -f "${HOOKS_JSON}" ]]; then
    log "detect hook missing: ${HOOKS_JSON}"
    return
  fi
  if grep -Fq "codex-sentinel-server" "${HOOKS_JSON}"; then
    log "detect hook reference: ${HOOKS_JSON}"
  else
    log "detect hook has no codex-sentinel-server reference: ${HOOKS_JSON}"
  fi
}

detect_all() {
  detect_legacy_service
  detect_path "unit" "${UNIT_PATH}"
  detect_path "opt" "${OPT_DIR}"
  detect_path "etc" "${ETC_DIR}"
  detect_path "state" "${STATE_DIR}"
  detect_path "bin" "${BIN_PATH}"
  detect_hooks
}

health_gate() {
  log "health gate: systemctl is-active nexushub"
  systemctl is-active nexushub >/dev/null
  if [[ "${NEXUSHUB_SERVICE}" != "nexushub" ]]; then
    systemctl is-active "${NEXUSHUB_SERVICE}" >/dev/null
  fi
  log "health gate: ${HEALTH_URL}"
  curl -fsS "${HEALTH_URL}" >/dev/null
}

backup_item() {
  local path="$1"
  local target_name="$2"
  local backup_dir="$3"
  [[ -e "${path}" ]] || return 0
  if [[ -d "${path}" && ! -L "${path}" ]]; then
    cp -a "${path}" "${backup_dir}/${target_name}"
  else
    cp -a "${path}" "${backup_dir}/${target_name}"
  fi
}

backup_all() {
  local backup_dir="${BACKUP_ROOT}/${STAMP}"
  install -d -m 0750 -o "${INSTALL_OWNER}" -g "${INSTALL_GROUP}" "${backup_dir}"
  backup_item "${UNIT_PATH}" "etc-systemd-system-codex-sentinel-server.service" "${backup_dir}"
  backup_item "${OPT_DIR}" "opt-codex-sentinel-server" "${backup_dir}"
  backup_item "${ETC_DIR}" "etc-codex-sentinel-server" "${backup_dir}"
  backup_item "${STATE_DIR}" "var-lib-codex-sentinel-server" "${backup_dir}"
  backup_item "${BIN_PATH}" "usr-local-bin-codex-sentinel-server" "${backup_dir}"
  backup_item "${HOOKS_JSON}" "root-codex-hooks.json" "${backup_dir}"
  log "backup complete: ${backup_dir}"
}

clean_hooks_json() {
  [[ -f "${HOOKS_JSON}" ]] || return 0
  if ! grep -Fq "codex-sentinel-server" "${HOOKS_JSON}"; then
    return 0
  fi
  python3 - "${HOOKS_JSON}" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
value = json.loads(path.read_text())
hooks = value.get("hooks")
if isinstance(hooks, dict):
    empty_events = []
    for event, groups in list(hooks.items()):
        if not isinstance(groups, list):
            continue
        next_groups = []
        for group in groups:
            if not isinstance(group, dict):
                next_groups.append(group)
                continue
            items = group.get("hooks")
            if not isinstance(items, list):
                next_groups.append(group)
                continue
            group["hooks"] = [
                item for item in items
                if not (
                    isinstance(item, dict)
                    and "codex-sentinel-server" in str(item.get("command", ""))
                )
            ]
            if group["hooks"]:
                next_groups.append(group)
        if next_groups:
            hooks[event] = next_groups
        else:
            empty_events.append(event)
    for event in empty_events:
        hooks.pop(event, None)
path.write_text(json.dumps(value, indent=2, ensure_ascii=False) + "\n")
PY
  log "removed codex-sentinel-server hook references from ${HOOKS_JSON}"
}

execute_cleanup() {
  health_gate
  backup_all
  systemctl stop codex-sentinel-server.service >/dev/null 2>&1 || true
  systemctl disable codex-sentinel-server.service >/dev/null 2>&1 || true
  rm -f "${UNIT_PATH}" "${BIN_PATH}"
  rm -rf "${OPT_DIR}" "${ETC_DIR}" "${STATE_DIR}"
  clean_hooks_json
  systemctl daemon-reload >/dev/null 2>&1 || true
  log "execute complete"
}

main() {
  parse_args "$@"
  require_root
  detect_all
  if [[ "${MODE}" == "dry-run" ]]; then
    log "DRY-RUN only; no files removed"
    log "execute requires NexusHub health gate before backup and cleanup"
    return 0
  fi
  execute_cleanup
}

main "$@"
