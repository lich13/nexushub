#!/usr/bin/env bash
set -Eeuo pipefail

LABEL="com.nexushub.cloudflared"
PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"
CLOUDFLARED_BIN="${CLOUDFLARED_BIN:-}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../../.." >/dev/null 2>&1 && pwd -P)"
CONFIG_PATH=""
TUNNEL_NAME=""
LOG_PATH="${HOME}/Library/Logs/NexusHub/cloudflared.log"

usage() {
  cat <<'USAGE'
Usage:
  cloudflared-nexushub check
  cloudflared-nexushub install --config PATH --tunnel NAME_OR_UUID [--log PATH]
  cloudflared-nexushub uninstall
  cloudflared-nexushub status

This helper only manages a local macOS LaunchAgent for an existing
locally-managed Cloudflare Tunnel config. It does not create Cloudflare accounts,
zones, DNS records, Access apps, tunnels, credentials, or tokens.
USAGE
}

die() {
  printf 'cloudflared-nexushub: %s\n' "$*" >&2
  exit 1
}

detect_cloudflared() {
  if [[ -n "${CLOUDFLARED_BIN}" ]]; then
    [[ -x "${CLOUDFLARED_BIN}" ]] || die "CLOUDFLARED_BIN is not executable: ${CLOUDFLARED_BIN}"
    return
  fi
  CLOUDFLARED_BIN="$(command -v cloudflared || true)"
  [[ -n "${CLOUDFLARED_BIN}" ]] || die "cloudflared not found; install it from Cloudflare docs or Homebrew"
}

parse_install_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        [[ $# -ge 2 ]] || die "--config requires a path"
        CONFIG_PATH="$2"
        shift 2
        ;;
      --tunnel)
        [[ $# -ge 2 ]] || die "--tunnel requires a name or UUID"
        TUNNEL_NAME="$2"
        shift 2
        ;;
      --log)
        [[ $# -ge 2 ]] || die "--log requires a path"
        LOG_PATH="$2"
        shift 2
        ;;
      --token|--url-token)
        die "token arguments are intentionally unsupported; do not pass tunnel tokens through this helper"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown install argument: $1"
        ;;
    esac
  done
  [[ -n "${CONFIG_PATH}" ]] || die "--config is required"
  [[ -n "${TUNNEL_NAME}" ]] || die "--tunnel is required"
  [[ -f "${CONFIG_PATH}" ]] || die "config file not found: ${CONFIG_PATH}"
  local resolved_config resolved_repo
  resolved_config="$(cd -- "$(dirname -- "${CONFIG_PATH}")" >/dev/null 2>&1 && pwd -P)/$(basename -- "${CONFIG_PATH}")"
  resolved_repo="${REPO_ROOT}"
  case "${resolved_config}" in
    "${resolved_repo}"/*|./*|../*)
      die "keep Cloudflare credentials/config outside the repository"
      ;;
  esac
  CONFIG_PATH="${resolved_config}"
}

xml_escape() {
  local value="$1"
  value="${value//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  value="${value//\"/&quot;}"
  value="${value//\'/&apos;}"
  printf '%s' "${value}"
}

write_plist() {
  mkdir -p "$(dirname "${PLIST}")" "$(dirname "${LOG_PATH}")"
  local escaped_bin escaped_config escaped_log escaped_tunnel
  escaped_bin="$(xml_escape "${CLOUDFLARED_BIN}")"
  escaped_config="$(xml_escape "${CONFIG_PATH}")"
  escaped_log="$(xml_escape "${LOG_PATH}")"
  escaped_tunnel="$(xml_escape "${TUNNEL_NAME}")"
  cat >"${PLIST}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${escaped_bin}</string>
    <string>tunnel</string>
    <string>--config</string>
    <string>${escaped_config}</string>
    <string>--logfile</string>
    <string>${escaped_log}</string>
    <string>--loglevel</string>
    <string>info</string>
    <string>run</string>
    <string>${escaped_tunnel}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${escaped_log}</string>
  <key>StandardErrorPath</key>
  <string>${escaped_log}</string>
</dict>
</plist>
PLIST
}

check() {
  detect_cloudflared
  "${CLOUDFLARED_BIN}" --version
}

install_agent() {
  detect_cloudflared
  parse_install_args "$@"
  write_plist
  launchctl bootout "gui/$(id -u)" "${PLIST}" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "${PLIST}"
  launchctl kickstart -k "gui/$(id -u)/${LABEL}"
  printf 'installed %s\n' "${PLIST}"
}

uninstall_agent() {
  launchctl bootout "gui/$(id -u)" "${PLIST}" >/dev/null 2>&1 || true
  rm -f "${PLIST}"
  printf 'removed %s\n' "${PLIST}"
}

status() {
  launchctl print "gui/$(id -u)/${LABEL}" 2>/dev/null || {
    printf '%s is not loaded\n' "${LABEL}"
    return 1
  }
}

main() {
  local command="${1:-}"
  [[ $# -gt 0 ]] && shift || true
  case "${command}" in
    check) check ;;
    install) install_agent "$@" ;;
    uninstall) uninstall_agent ;;
    status) status ;;
    -h|--help|"") usage ;;
    *) die "unknown command: ${command}" ;;
  esac
}

main "$@"
