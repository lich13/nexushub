#!/usr/bin/env bash
set -Eeuo pipefail

unit="nexushub-codex-precheck-$(date +%s)-$$"

exec systemd-run \
  --wait \
  --collect \
  --pipe \
  --unit="${unit}" \
  --property=User=root \
  --property=Group=root \
  --property=Type=exec \
  --property=WorkingDirectory=/home/ubuntu/codex-workspace \
  --property=ProtectSystem=no \
  --property=ProtectHome=no \
  /usr/bin/env bash -lc '
set -Eeuo pipefail
sudo -n codex --version
sudo -n codex mcp list
/usr/local/bin/codex-raw --version
sqlite3 /root/.codex/state_5.sqlite "pragma integrity_check;"
/home/ubuntu/codex-admin/bin/codex-cloud-doctor
'
